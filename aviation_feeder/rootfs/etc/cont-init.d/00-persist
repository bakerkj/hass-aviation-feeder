#!/command/with-contenv sh
# shellcheck shell=sh
# Persist data that must survive add-on rebuilds/updates on the /data volume.
#
# A HA add-on's container filesystem is ephemeral: it is recreated on every
# rebuild, update, or reinstall, so anything written under the container's own
# paths is lost. Only /data is a persistent volume. The upstream ultrafeeder
# docker-compose maps out /var/globe_history and /var/lib/collectd as named
# volumes for exactly this reason; we do the equivalent by symlinking them (and
# the piaware identity cache) onto /data before any service starts.
#
#   /var/globe_history  readsb --write-state: flight history, heatmap, replay
#   /var/lib/collectd   graphs1090 long-term stats (signal/rate/range RRDs; the
#                       hourly gzip archive -- live RRDs stay in RAM, see
#                       00-tmpfs-readsb + GRAPHS1090_REDUCE_IO)
#   /var/cache/piaware  piaware's auto-generated feeder-id + location.env (only
#                       matters when no FlightAware feeder ID is configured, but
#                       harmless otherwise)
#
# Without this you get "state directory didn't exist, created it" and a reset
# heatmap/graphs on every rebuild. Runs as a cont-init oneshot, before longruns.

# persist <container-path> <data-subdir>: make <container-path> a symlink into
# /data/<subdir>, migrating any pre-seeded content into the persistent dir once.
persist() {
  src="$1"
  dst="/data/$2"
  mkdir -p "${dst}"
  if [ -L "${src}" ]; then
    return 0
  fi
  if [ -e "${src}" ]; then
    # first run: move image-seeded content into the persistent dir, then replace
    cp -a "${src}/." "${dst}/" 2>/dev/null || true
    rm -rf "${src}"
  fi
  mkdir -p "$(dirname "${src}")"
  ln -s "${dst}" "${src}"
  echo "[persist] ${src} -> ${dst}"
}

persist /var/globe_history globe_history
persist /var/lib/collectd collectd
persist /var/cache/piaware piaware
