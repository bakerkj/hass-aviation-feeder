#!/command/with-contenv bash
#shellcheck shell=bash disable=SC2016
# Override of the upstream opensky-feeder script. openskyd-dump1090 self-logs via
# awk, bypassing the s6wrap-color shim -- so its [opensky-feeder] tag was
# uncoloured and used a slash-date timestamp unlike every other service. Match
# the s6wrap timestamp format (dash date) and wrap the tag in cyan (SGR 36,
# opensky's assigned colour in s6wrap-color) so it reads consistently in the HA
# add-on log. The SC2016 disable is correct: awk expands strftime/\033, not the
# shell. NOTE: strftime()/systime() are gawk extensions -- the base image's `awk`
# is GNU awk (as it was for the upstream script this overrides), so this is safe;
# it would break only if `awk` were ever swapped to mawk.
/usr/bin/openskyd-dump1090 2>&1 |
  stdbuf -oL awk '{print "[" strftime("%Y-%m-%d %H:%M:%S", systime()) "]\033[36m[opensky-feeder]\033[0m " $0}'
