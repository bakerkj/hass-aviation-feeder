  "schema": {
    "lat": "match([+-]?(([1-9][0-9]*)|(0))([.,][0-9]+)?|HOMEASSISTANT_LATITUDE)?",
    "long": "match([+-]?(([1-9][0-9]*)|(0))([.,][0-9]+)?|HOMEASSISTANT_LONGITUDE)?",
    "alt": "match(-?(([1-9][0-9]*)|(0))|HOMEASSISTANT_ELEVATION)?",
    "tz": "str?",
    "site_name": "str?",
    "mlat_user": "str?",
