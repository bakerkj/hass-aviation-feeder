{
  "name": "Aviation Feeder",
  "slug": "aviation_feeder",
  "description": "Merged ADS-B (1090) + UAT (978) + MLAT feeder with tar1090 map, built on docker-adsb-ultrafeeder.",
  "url": "https://github.com/bakerkj/hass-aviation-feeder",
  "image": "ghcr.io/bakerkj/{arch}-aviation_feeder",
  "version": "0.0.5",
  "arch": [
    "amd64",
    "aarch64"
  ],
  "init": false,
  "startup": "services",
  "usb": true,
  "tmpfs": true,
  "ingress": true,
  "ingress_port": 80,
  "panel_icon": "mdi:airplane",
  "homeassistant_api": true,
  "hassio_api": true,
  "services": [
    "mqtt:want"
  ],
  "ports": {
    "80/tcp": 8504,
    "30003/tcp": null,
    "30005/tcp": null,
    "30978/tcp": null,
    "30053/tcp": null
  },
  "ports_description": {
    "80/tcp": "tar1090 web UI (direct access; ingress works regardless)",
    "30003/tcp": "readsb SBS/BaseStation output (optional; off by default)",
    "30005/tcp": "readsb Beast output (optional; off by default)",
    "30978/tcp": "dump978 raw UAT output (optional; off by default)",
    "30053/tcp": "PlaneFinder client status/map UI (optional; off by default)"
  },
  "options": {
    "lat": "HOMEASSISTANT_LATITUDE",
    "long": "HOMEASSISTANT_LONGITUDE",
    "alt": "HOMEASSISTANT_ELEVATION",
    "tz": "Etc/UTC",
    "site_name": "",
    "mlat_user": "",
    "uuid": "",
    "receiver_mode": "rtlsdr",
    "remote_beast_host": "",
    "remote_beast_port": 30005,
    "readsb_rtlsdr_device": "",
    "readsb_gain": "autogain",
    "readsb_ppm": 0,
    "enable_uat": false,
    "dump978_rtlsdr_device": "",
    "dump978_gain": "autogain",
    "dump978_ppm": 0,
    "feed_adsbexchange": false,
    "adsbexchange_uuid": "",
    "adsbexchange_name": "",
    "adsbexchange_mlat": true,
    "feed_adsbfi": false,
    "adsbfi_uuid": "",
    "adsbfi_name": "",
    "adsbfi_mlat": true,
    "enable_adsbhub": false,
    "adsbhub_clientkey": "",
    "feed_adsbitalia": false,
    "adsbitalia_uuid": "",
    "adsbitalia_name": "",
    "adsbitalia_mlat": true,
    "feed_adsblol": false,
    "adsblol_uuid": "",
    "adsblol_name": "",
    "adsblol_mlat": true,
    "feed_adsbone": false,
    "adsbone_uuid": "",
    "adsbone_name": "",
    "adsbone_mlat": true,
    "enable_radarbox": false,
    "radarbox_sharing_key": "",
    "radarbox_mlat": true,
    "feed_airplaneslive": false,
    "airplaneslive_uuid": "",
    "airplaneslive_name": "",
    "airplaneslive_mlat": true,
    "feed_avdelphi": false,
    "avdelphi_uuid": "",
    "enable_piaware": false,
    "piaware_feeder_id": "",
    "enable_fr24": false,
    "fr24_key": "",
    "fr24_uat_key": "",
    "feed_flyitaly": false,
    "flyitaly_uuid": "",
    "flyitaly_name": "",
    "flyitaly_mlat": true,
    "feed_hpradar": false,
    "hpradar_uuid": "",
    "hpradar_name": "",
    "hpradar_mlat": true,
    "enable_opensky": false,
    "opensky_username": "",
    "opensky_serial": "",
    "enable_planefinder": false,
    "planefinder_sharecode": "",
    "feed_planespotters": false,
    "planespotters_uuid": "",
    "planespotters_name": "",
    "planespotters_mlat": true,
    "enable_planewatch": false,
    "planewatch_api_key": "",
    "enable_radarvirtuel": false,
    "radarvirtuel_contrib_name": "",
    "radarvirtuel_contrib_email": "",
    "radarvirtuel_station_uid": "",
    "enable_sdrmap": false,
    "sdrmap_username": "",
    "sdrmap_password": "",
    "feed_theairtraffic": false,
    "theairtraffic_uuid": "",
    "theairtraffic_name": "",
    "theairtraffic_mlat": true,
    "enable_uk1090": false,
    "uk1090_key": "",
    "ha_sensors": false,
    "ha_feeder_health": true,
    "ha_planes_near_me": true,
